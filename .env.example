# Copy to .env.local for local dev, and set the same vars in Vercel (Production).
# Never commit real values — .env*.local is gitignored.

# The shared site password visitors type to get past the gate.
SITE_PASSWORD=change-me-to-a-shared-password

# Secret used to encrypt/sign the session cookie. MUST be at least 32 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars-long
